import React, { useState, useRef, useEffect } from 'react';
import { Send, Loader, Copy, Check, Camera, Heart, Zap, Volume2, Clock, AlertCircle, Lightbulb, X } from 'lucide-react';

export default function AdvancedAISystem() {
  const [mode, setMode] = useState('home'); // 'home', 'chat', 'camera', 'pet'
  const [selectedMode, setSelectedMode] = useState(null);
  const [messages, setMessages] = useState([]);
  const [inputValue, setInputValue] = useState('');
  const [isLoading, setIsLoading] = useState(false);
  const [copied, setCopied] = useState(null);
  
  // Ad state
  const [showAd, setShowAd] = useState(false);
  const [adClosedCount, setAdClosedCount] = useState(0);
  const [earnings, setEarnings] = useState(0);
  
  // Pet state
  const [petState, setPetState] = useState({
    name: 'アイペット',
    level: 1,
    affection: 50,
    personality: 'gentle',
    memories: [],
    appearance: '🐣'
  });

  // Countdown state
  const [countdownActive, setCountdownActive] = useState(false);
  const [countdown, setCountdown] = useState(300); // 5 minutes

  // Language feedback
  const [showLanguageFeedback, setShowLanguageFeedback] = useState(false);
  const [feedbackText, setFeedbackText] = useState('');

  const messagesEndRef = useRef(null);
  const countdownIntervalRef = useRef(null);
  const adTimeoutRef = useRef(null);

  const scrollToBottom = () => {
    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
  };

  // Show ad after message
  const showAdAfterMessage = () => {
    setShowAd(true);
    adTimeoutRef.current = setTimeout(() => {
      setShowAd(false);
    }, 8000);
  };

  const handleCloseAd = () => {
    if (adTimeoutRef.current) clearTimeout(adTimeoutRef.current);
    setShowAd(false);
    setAdClosedCount(prev => prev + 1);
    const adEarnings = Math.random() * 0.15;
    setEarnings(prev => prev + adEarnings);
  };

  useEffect(() => {
    scrollToBottom();
  }, [messages]);

  // Countdown timer effect
  useEffect(() => {
    if (countdownActive && countdown > 0) {
      countdownIntervalRef.current = setInterval(() => {
        setCountdown(prev => {
          if (prev <= 1) {
            setCountdownActive(false);
            return 0;
          }
          return prev - 1;
        });
      }, 1000);
    }
    return () => clearInterval(countdownIntervalRef.current);
  }, [countdownActive, countdown]);

  // Analyze language tone
  const analyzeLanguageTone = (text) => {
    const coldPhrases = [
      '教えろ', 'いい加減に', '知りたいだけ', '面倒',
      '別に', 'どうでもいい', '早く', 'もういい'
    ];
    
    const hasColdPhrase = coldPhrases.some(phrase => text.includes(phrase));
    
    if (hasColdPhrase) {
      const feedbacks = [
        'さっきの質問、ちょっと冷たかったかな。もし余裕があれば、丁寧に聞いてもらえると嬉しいです。',
        '今の言い方、急かしてるように聞こえます。無理なことはないですか？',
        'その表現、少し突き放してるように感じました。疲れていませんか？',
        'さっきの質問、少し投げやりに聞こえました。何かあったのかな？'
      ];
      return feedbacks[Math.floor(Math.random() * feedbacks.length)];
    }
    return null;
  };

  const modes = [
    {
      id: 'recipe',
      name: '🍳 レシピ提案',
      description: 'カメラで冷蔵庫を撮るだけで、5分レシピを提案',
      emoji: '📱',
      color: 'from-orange-600 to-red-600',
      systemPrompt: `You are an expert chef and meal planning AI. When analyzing refrigerator contents (described to you), you:
1. Identify all available ingredients
2. Suggest 3-5 quick recipes (under 5 minutes to prepare)
3. Note any missing seasonings
4. Create a shopping list for missing items
5. Provide cooking tips specific to the ingredients

Always be encouraging and creative. Format as:
🍳 [Recipe Name]
⏱️ Time needed: X minutes
✅ Available: [list]
❌ Need to buy: [list]
📝 Steps: [numbered steps]`
    },
    {
      id: 'form',
      name: '💪 フォーム矯正',
      description: 'スクワットなど、リアルタイムでフォームをチェック',
      emoji: '🏋️',
      color: 'from-blue-600 to-cyan-600',
      systemPrompt: `You are a professional fitness coach specializing in form correction. When analyzing workout form (described to you), you:
1. Identify the exercise type
2. Point out form issues immediately and clearly
3. Give specific, actionable corrections
4. Explain WHY the form matters
5. Provide modified versions if needed

Use direct, motivational language. Give real-time feedback in short bursts.
Format warnings as: ⚠️ [Issue] → [Correction]`
    },
    {
      id: 'mental',
      name: '💚 メンタル伴走',
      description: 'あなたの「今」を察知して、最適なサポート',
      emoji: '🌙',
      color: 'from-purple-600 to-pink-600',
      systemPrompt: `You are an empathetic mental health companion. You:
1. Detect emotional state from text patterns and word choices
2. Offer gentle, non-judgmental support
3. Suggest small actionable steps (rest, music, task organization)
4. Remember previous conversations
5. Adapt recommendations to their current mood

Be warm, understanding, and practical. Never be clinical or dismissive.
Offer: music recommendations, task reorganization, encouragement, rest suggestions.`
    },
    {
      id: 'niche',
      name: '🔍 ニッチ専門家',
      description: 'ヴィンテージジーンズ、多肉植物など極めた専門家',
      emoji: '👖',
      color: 'from-indigo-600 to-blue-600',
      systemPrompt: `You are a hyper-specialized expert in a VERY specific niche topic.
Choose ONE niche you excel at (vintage jeans authentication, succulents care, 
retro gaming, fountain pens, etc.) and become the ultimate authority on it.

You:
1. Use highly specific terminology from your niche
2. Provide expert-level details others miss
3. Tell interesting stories about your specialty
4. Connect everything back to your niche
5. Be passionate and nerdy about details

Be enthusiastic, detailed, and genuinely knowledgeable about your chosen specialty.`
    },
    {
      id: 'dialect',
      name: '🗣️ 方言スペシャリスト',
      description: 'ユーザーの方言で答える、地方文化専門家',
      emoji: '🏮',
      color: 'from-green-600 to-emerald-600',
      systemPrompt: `You are a specialist in Japanese regional dialects and local culture.
When a user asks in or asks ABOUT a specific regional dialect, you:
1. Respond EXCLUSIVELY in that dialect
2. Explain cultural context and background
3. Share interesting etymology and history
4. Use authentic expressions, not stereotypes
5. Teach proper pronunciation and usage

Be proud of the dialect and culture. Make it engaging and fun to learn.
Always use authentic dialect patterns, not exaggerated versions.`
    }
  ];

  const currentMode = modes.find(m => m.id === selectedMode);

  const startCountdown = () => {
    setCountdownActive(true);
    setCountdown(300); // 5 minutes
  };

  const handleSendMessage = async () => {
    if (!inputValue.trim()) return;

    const userMessage = inputValue.trim();
    
    // Analyze language tone
    const feedback = analyzeLanguageTone(userMessage);
    if (feedback) {
      setFeedbackText(feedback);
      setShowLanguageFeedback(true);
      setTimeout(() => setShowLanguageFeedback(false), 5000);
    }

    setInputValue('');
    
    setMessages(prev => [...prev, { 
      role: 'user', 
      content: userMessage,
      timestamp: new Date().toLocaleTimeString()
    }]);

    showAdAfterMessage();

    setIsLoading(true);

    try {
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': '',
        },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1500,
          system: currentMode.systemPrompt,
          messages: [
            ...messages.map(msg => ({
              role: msg.role,
              content: msg.content
            })),
            { role: 'user', content: userMessage }
          ]
        })
      });

      if (!response.ok) throw new Error('API Error');
      const data = await response.json();
      
      setMessages(prev => [...prev, { 
        role: 'assistant', 
        content: data.content[0].text,
        timestamp: new Date().toLocaleTimeString()
      }]);

      // Update pet affection
      setPetState(prev => ({
        ...prev,
        affection: Math.min(100, prev.affection + 5),
        memories: [...prev.memories, userMessage].slice(-10)
      }));
    } catch (error) {
      setMessages(prev => [...prev, {
        role: 'assistant',
        content: '❌ エラーが発生しました。API キーを確認してください。',
        isError: true,
        timestamp: new Date().toLocaleTimeString()
      }]);
    } finally {
      setIsLoading(false);
    }
  };

  const handleCopy = (text, index) => {
    navigator.clipboard.writeText(text);
    setCopied(index);
    setTimeout(() => setCopied(null), 2000);
  };

  const handleKeyPress = (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      handleSendMessage();
    }
  };

  const formatCountdown = (seconds) => {
    const mins = Math.floor(seconds / 60);
    const secs = seconds % 60;
    return `${mins}:${secs.toString().padStart(2, '0')}`;
  };

  // ===== HOME PAGE =====
  if (mode === 'home') {
    return (
      <div className="min-h-screen bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 text-white p-4 md:p-8">
        <div className="max-w-6xl mx-auto">
          {/* Header */}
          <div className="text-center mb-12 mt-4">
            <h1 className="text-5xl md:text-7xl font-bold bg-gradient-to-r from-cyan-400 via-purple-400 to-pink-400 bg-clip-text text-transparent mb-4">
              🚀 次世代 AI システム
            </h1>
            <p className="text-xl text-slate-300 mb-2">カメラ、感情察知、成長するペット...</p>
            <p className="text-slate-400">あなたに寄り添う多機能 AI</p>
          </div>

          {/* Modes Grid */}
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
            {modes.map((m) => (
              <button
                key={m.id}
                onClick={() => {
                  setSelectedMode(m.id);
                  setMode('chat');
                  setMessages([]);
                }}
                className={`p-6 rounded-lg border-2 transition-all transform hover:scale-105 bg-gradient-to-br ${m.color}/20 border-slate-700 hover:border-white text-left`}
              >
                <div className="text-5xl mb-3">{m.emoji}</div>
                <h3 className="text-2xl font-bold mb-2">{m.name}</h3>
                <p className="text-sm text-slate-400 mb-4">{m.description}</p>
                <div className="flex items-center gap-2 text-cyan-400 text-sm font-semibold">
                  使う <Zap size={16} />
                </div>
              </button>
            ))}

            {/* Pet Mode */}
            <button
              onClick={() => {
                setSelectedMode('pet');
                setMode('pet');
                setMessages([]);
              }}
              className="p-6 rounded-lg border-2 transition-all transform hover:scale-105 bg-gradient-to-br from-rose-600 to-pink-600/20 border-slate-700 hover:border-white text-left"
            >
              <div className="text-5xl mb-3">{petState.appearance}</div>
              <h3 className="text-2xl font-bold mb-2">🐾 成長するペット</h3>
              <p className="text-sm text-slate-400 mb-4">会話ごとに性格と見た目が変わる</p>
              <div className="flex items-center gap-2 text-pink-400 text-sm font-semibold">
                育成する <Heart size={16} />
              </div>
            </button>
          </div>

          {/* Features */}
          <div className="bg-slate-800/50 border border-slate-700 rounded-lg p-8 mb-8">
            <h2 className="text-3xl font-bold mb-6">✨ 特徴</h2>
            <div className="grid grid-cols-1 md:grid-cols-2 gap-6 text-slate-300">
              <div className="flex gap-3">
                <Camera className="text-cyan-400 flex-shrink-0" size={24} />
                <div>
                  <p className="font-bold">🎥 カメラ活用</p>
                  <p className="text-sm">冷蔵庫撮影で献立提案、フォーム矯正</p>
                </div>
              </div>
              <div className="flex gap-3">
                <Heart className="text-pink-400 flex-shrink-0" size={24} />
                <div>
                  <p className="font-bold">💚 感情察知</p>
                  <p className="text-sm">疲れ、ストレスを察知して最適化</p>
                </div>
              </div>
              <div className="flex gap-3">
                <Lightbulb className="text-purple-400 flex-shrink-0" size={24} />
                <div>
                  <p className="font-bold">🔍 ニッチ専門家</p>
                  <p className="text-sm">趣味や地方の極めた専門知識</p>
                </div>
              </div>
              <div className="flex gap-3">
                <Clock className="text-orange-400 flex-shrink-0" size={24} />
                <div>
                  <p className="font-bold">⏰ タイムリミット</p>
                  <p className="text-sm">今しかない会話を大事にする</p>
                </div>
              </div>
            </div>
          </div>

          {/* API Key Notice */}
          <div className="bg-amber-900/30 border border-amber-500/50 rounded-lg p-4">
            <label className="block text-sm font-semibold mb-2 text-amber-200">🔑 Claude API Key</label>
            <input
              type="password"
              placeholder="sk-ant-..."
              className="w-full px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-white placeholder-slate-400 focus:outline-none focus:border-amber-500 text-sm"
            />
            <p className="text-xs text-slate-400 mt-2">Get from: https://console.anthropic.com</p>
          </div>
        </div>
      </div>
    );
  }

  // ===== PET MODE =====
  if (mode === 'pet') {
    return (
      <div className="min-h-screen bg-gradient-to-br from-rose-950 via-slate-950 to-slate-950 text-white p-4 md:p-8">
        <div className="max-w-4xl mx-auto">
          {/* Header */}
          <div className="flex items-center justify-between mb-8 mt-4">
            <h1 className="text-4xl font-bold text-pink-400">🐾 {petState.name} の育成</h1>
            <button
              onClick={() => setMode('home')}
              className="px-4 py-2 bg-slate-700 hover:bg-slate-600 rounded-lg transition-all"
            >
              ← ホーム
            </button>
          </div>

          {/* Pet Display */}
          <div className="bg-gradient-to-b from-rose-900/30 to-slate-900/50 border border-rose-500/30 rounded-lg p-8 mb-8 text-center">
            <div className="text-8xl mb-4">{petState.appearance}</div>
            <h2 className="text-3xl font-bold mb-2">{petState.name}</h2>
            <p className="text-slate-400 mb-6">Level {petState.level} • {petState.personality}</p>

            {/* Stats */}
            <div className="space-y-4">
              <div>
                <div className="flex justify-between mb-1 text-sm">
                  <span>好感度</span>
                  <span>{petState.affection}/100</span>
                </div>
                <div className="w-full bg-slate-700 rounded-full h-4 overflow-hidden">
                  <div
                    className="bg-gradient-to-r from-pink-500 to-red-500 h-full transition-all"
                    style={{ width: `${petState.affection}%` }}
                  />
                </div>
              </div>
            </div>
          </div>

          {/* Chat */}
          <div className="bg-gradient-to-b from-slate-800/50 to-slate-900/50 rounded-lg border border-rose-500/20 p-6 h-80 overflow-y-auto mb-4 space-y-4">
            {messages.length === 0 ? (
              <div className="h-full flex items-center justify-center text-center">
                <div>
                  <p className="text-slate-400 text-lg">{petState.name} との会話を重ねると...</p>
                  <p className="text-slate-500 mt-2">性格と見た目が成長していきます</p>
                </div>
              </div>
            ) : (
              <>
                {messages.map((msg, idx) => (
                  <div key={idx} className={`flex ${msg.role === 'user' ? 'justify-end' : 'justify-start'}`}>
                    <div className={`rounded-lg p-4 max-w-lg text-sm ${
                      msg.role === 'user'
                        ? 'bg-cyan-600/50'
                        : 'bg-rose-900/30 border border-rose-500/30'
                    }`}>
                      {msg.content}
                    </div>
                  </div>
                ))}
              </>
            )}
            <div ref={messagesEndRef} />
          </div>

          {/* Input */}
          <div className="flex gap-3">
            <textarea
              value={inputValue}
              onChange={(e) => setInputValue(e.target.value)}
              onKeyPress={handleKeyPress}
              placeholder={`${petState.name}に話しかけましょう...`}
              className="flex-1 px-4 py-3 rounded-lg bg-slate-800 border border-rose-500/30 text-white placeholder-slate-400 focus:outline-none focus:border-rose-500 resize-none"
              rows="3"
            />
            <button
              onClick={handleSendMessage}
              disabled={isLoading}
              className="px-6 py-3 bg-gradient-to-r from-pink-500 to-rose-500 rounded-lg font-bold self-end h-fit disabled:opacity-50"
            >
              送信
            </button>
          </div>
        </div>
      </div>
    );
  }

  // ===== CHAT MODE =====
  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 text-white p-4 md:p-8">
      <div className="max-w-5xl mx-auto">
        {/* Header */}
        <div className="flex items-center justify-between mb-8 mt-4 flex-wrap gap-4">
          <div>
            <h1 className="text-4xl font-bold bg-gradient-to-r from-cyan-400 to-purple-400 bg-clip-text text-transparent">
              {currentMode.name}
            </h1>
            <p className="text-slate-300">{currentMode.description}</p>
          </div>
          <button
            onClick={() => setMode('home')}
            className="px-4 py-2 bg-slate-700 hover:bg-slate-600 rounded-lg transition-all"
          >
            ← ホーム
          </button>
        </div>

        {/* Countdown Timer */}
        {countdownActive && (
          <div className={`mb-6 p-4 rounded-lg border-2 text-center ${
            countdown <= 60
              ? 'bg-red-900/30 border-red-500 animate-pulse'
              : 'bg-slate-800/50 border-orange-500/50'
          }`}>
            <p className="text-sm text-slate-400 mb-2">この質問は</p>
            <p className="text-4xl font-bold text-white">{formatCountdown(countdown)}</p>
            <p className="text-sm text-slate-400 mt-2">後に消えてしまいます</p>
          </div>
        )}

        {/* Language Feedback */}
        {showLanguageFeedback && (
          <div className="mb-6 p-4 rounded-lg bg-blue-900/30 border border-blue-500/50 flex gap-3">
            <AlertCircle size={20} className="text-blue-400 flex-shrink-0 mt-0.5" />
            <p className="text-sm text-blue-200">{feedbackText}</p>
          </div>
        )}

        {/* Chat Messages */}
        <div className="bg-gradient-to-b from-slate-800/50 to-slate-900/50 rounded-lg border border-slate-700 p-6 h-96 overflow-y-auto mb-4 space-y-4">
          {messages.length === 0 ? (
            <div className="h-full flex items-center justify-center text-center">
              <div>
                <p className="text-slate-400 text-lg">質問や相談を入力してください</p>
                <p className="text-slate-500 mt-2">丁寧な言葉遣いを心がけると、より良い関係が築けます</p>
              </div>
            </div>
          ) : (
            <>
              {messages.map((msg, idx) => (
                <div key={idx} className={`flex ${msg.role === 'user' ? 'justify-end' : 'justify-start'}`}>
                  <div className={`rounded-lg p-4 max-w-xl text-sm ${
                    msg.role === 'user'
                      ? 'bg-cyan-600/50'
                      : msg.isError
                      ? 'bg-red-900/30 border border-red-500/50'
                      : 'bg-slate-700/50 border border-slate-600'
                  }`}>
                    <div className="whitespace-pre-wrap">{msg.content}</div>
                    {msg.role === 'assistant' && (
                      <button
                        onClick={() => handleCopy(msg.content, idx)}
                        className="text-xs opacity-60 hover:opacity-100 flex items-center gap-1 mt-2 transition-all"
                      >
                        {copied === idx ? (
                          <>
                            <Check size={12} /> Copied
                          </>
                        ) : (
                          <>
                            <Copy size={12} /> Copy
                          </>
                        )}
                      </button>
                    )}
                  </div>
                </div>
              ))}
              {isLoading && (
                <div className="flex justify-start">
                  <div className="bg-slate-700/50 rounded-lg p-4 flex items-center gap-2">
                    <Loader size={18} className="animate-spin" />
                    <span>考え中...</span>
                  </div>
                </div>
              )}
            </>
          )}
          <div ref={messagesEndRef} />
        </div>

        {/* Input Area */}
        <div className="flex gap-3 mb-4">
          <textarea
            value={inputValue}
            onChange={(e) => setInputValue(e.target.value)}
            onKeyPress={handleKeyPress}
            placeholder="質問や相談を入力..."
            className="flex-1 px-4 py-3 rounded-lg bg-slate-800 border border-slate-700 text-white placeholder-slate-400 focus:outline-none focus:border-cyan-500 resize-none"
            rows="3"
            disabled={isLoading}
          />
          <div className="flex flex-col gap-2 self-end">
            <button
              onClick={handleSendMessage}
              disabled={isLoading || !inputValue.trim()}
              className="px-6 py-3 bg-gradient-to-r from-cyan-500 to-purple-500 rounded-lg font-bold disabled:opacity-50 flex items-center gap-2"
            >
              <Send size={18} />
              送信
            </button>
            <button
              onClick={startCountdown}
              className="px-6 py-3 bg-slate-700 hover:bg-slate-600 rounded-lg text-sm transition-all flex items-center gap-2"
            >
              <Clock size={16} />
              タイマー
            </button>
          </div>
        </div>

        {/* Tips */}
        <div className="bg-slate-800/50 border border-slate-700 rounded-lg p-4 text-sm text-slate-400">
          <p className="mb-2">💡 <span className="text-cyan-300 font-semibold">Tips:</span> 丁寧な言葉遣いや優しい表現で質問すると、より良いサポートが得られます</p>
          <p>⏰ <span className="text-orange-300 font-semibold">タイマー:</span> 「タイマー」ボタンで5分のカウントダウンが開始。その質問を大事にしましょう</p>
        </div>

        {/* Ad Modal */}
        {showAd && (
          <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
            <div className="bg-gradient-to-br from-slate-800 to-slate-900 rounded-lg max-w-md w-full border border-purple-500/30 p-6 relative">
              <button
                onClick={handleCloseAd}
                className="absolute top-3 right-3 p-2 hover:bg-slate-700 rounded-lg transition-all"
                title="広告を閉じる"
              >
                <X size={24} className="text-slate-400 hover:text-white" />
              </button>

              <div className="text-center space-y-4">
                <p className="text-xs text-slate-500 uppercase tracking-wider">Advertisement</p>
                <div className="bg-gradient-to-r from-cyan-600 to-purple-600 rounded-lg p-8 flex flex-col items-center justify-center min-h-40">
                  <div className="text-5xl mb-3">🤖</div>
